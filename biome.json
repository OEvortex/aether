{
    "$schema": "https://biomejs.dev/schemas/2.3.11/schema.json",
    "files": {
        "ignoreUnknown": true,
        "includes": [
            "**",
            "!dist",
            "!**/dist",
            "!node_modules",
            "!**/node_modules",
            "!.vscode-test",
            "!out",
            "!src/openclaude",
            "!src/aether",
            "!**/*.d.ts",
            "!extension.js",
            "!src/ui/*.js",
            "!package.json",
            "!biome.json",
            "!.vscode/settings.json"
        ]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "semicolons": "always",
            "trailingCommas": "none"
        }
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "style": {
                "useBlockStatements": "warn"
            },
            "suspicious": {
                "noEmptyBlockStatements": "off",
                "noExplicitAny": "error"
            },
            "correctness": {
                "noUnusedVariables": "error"
            }
        }
    },
    "overrides": [
        {
            "includes": ["**/*.test.ts", "**/*.test.tsx", "**/test/**"],
            "linter": {
                "rules": {
                    "suspicious": {
                        "noExplicitAny": "off"
                    }
                }
            }
        }
    ]
}
